# Server Port
PORT=5000  # Port number where your backend server will run

# MongoDB Connection String
MONGO_URL=your_mongodb_connection_string_here  # Example: mongodb+srv://user:password@cluster.mongodb.net/dbname

# JWT Secret Key
JWT_SEC=your_jwt_secret_key_here  # Secret key used for signing JWT tokens

# Gmail Configuration (For Sending Emails)
Gmail=your_gmail_email_here  # Example: your-email@gmail.com
Password=your_gmail_app_password_here  # App-specific password (not your normal Gmail password)

# Cloudinary Configuration (For Image Uploads)
CLOUD_NAME=your_cloudinary_cloud_name_here
CLOUD_API_KEY=your_cloudinary_api_key_here
CLOUD_API_SECRET=your_cloudinary_api_secret_here

# Stripe Payment Keys
Stripe_Secret_Key=your_stripe_secret_key_here
Stripe_Publisable_Key=your_stripe_publishable_key_here

# Frontend URL (CORS & Redirect URLs)
Frontend_Url=https://your-frontend-domain.com  # Example: https://your-frontend-app.com
